{
  "name": "@normalfinance/normal-stellar-amm",
  "description": "Normal is a synthetic asset protocol enabling investors to trade any crypto asset or real-world asset (RWA) from a single DEX",
  "version": "0.0.1",
  "scripts": {
    "env": "cp .env.example .env",
    "setup": "node initialize.js",
    "test": "pnpm run test:integration && pnpm run test:unit",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "scout": "cargo scout-audit --output-format html --output-path audits/scout/report.html",
    "deploy": "./scripts/deploy.sh admin",
    "contracts:setup": "./scripts/setup.sh admin",
    "sac:deploy": "./scripts/sac/deploy_asset_and_sac.sh",
    "sac:update": "./scripts/sac/set_sac_admin_to_pool.sh",
    "sac:lock": "./scripts/sac/lock_issuer.sh",
    "contracts:killswitch": "./scripts/admin/killswitch.sh admin",
    "contracts:upgrade:apply": "./scripts/admin/upgrade/apply.sh admin",
    "contracts:upgrade:commit": "./scripts/admin/upgrade/commit.sh admin",
    "contracts:upgrade:revert": "./scripts/admin/upgrade/revert.sh admin",
    "pool:deploy": "./scripts/admin/pool/deploy.sh admin",
    "pool:deposit": "./scripts/admin/pool/deposit.sh admin",
    "pool:withdraw": "./scripts/admin/pool/withdraw.sh admin",
    "pool:update": "./scripts/admin/pool/update.sh admin",
    "pool:swap": "./scripts/admin/pool/swap.sh",
    "oracle:register": "./scripts/admin/oracle/register.sh admin",
    "oracle:update": "./scripts/admin/oracle/update.sh admin",
    "buffer:resolve": "./scripts/admin/buffer/resolve.sh admin",
    "buffer:update": "./scripts/admin/buffer/update.sh admin",
    "if:resolve": "./scripts/admin/buffer/resolve.sh admin",
    "if:update": "./scripts/admin/if/update.sh admin",
    "fees:collect": "./scripts/admin/fees/collect.sh admin"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/normalfinance/normal-stellar-amm.git"
  },
  "author": "Normal",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/normalfinance/normal-stellar-amm/issues"
  },
  "homepage": "https://github.com/normalfinance/normal-stellar-amm",
  "devDependencies": {
    "glob": "^11.0.2"
  },
  "type": "module",
  "dependencies": {}
}
